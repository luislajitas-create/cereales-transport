generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolNombre {
  ADMINISTRADOR
  GERENCIA
  OPERACIONES
  LIQUIDACIONES
  FACTURACION
  LECTURA
}

enum EstadoViajeEnum {
  PENDIENTE
  ASIGNADO
  EN_CARGA
  CARGADO
  EN_TRANSITO
  DESCARGADO
  CANCELADO
}

enum EstadoFacturacionEnum {
  PENDIENTE_DE_FACTURAR
  FACTURADO
  COBRADO_PARCIAL
  COBRADO_TOTAL
  ANULADO
}

enum EstadoLiquidacionItemEnum {
  PENDIENTE
  LIQUIDADO
  PAGADO
}

enum TipoVehiculo {
  CAMION
  ACOPLADO
}

enum TipoUbicacion {
  ACOPIO
  PLANTA
  PUERTO
  CAMPO
  OTRO
}

enum TipoLiquidacion {
  TRANSPORTISTA
  CHOFER
}

enum EstadoLiquidacionEnum {
  BORRADOR
  CONFIRMADA
  PAGADA
  ANULADA
}

enum EstadoFacturaEnum {
  FACTURADO
  COBRADO_PARCIAL
  COBRADO_TOTAL
  ANULADO
}

// Bloque 10.1 — nivel opcional por encima de Organizacion, para representar un grupo
// económico que opera con más de un CUIT. Ver GRUPO_ECONOMICO_DISENO_TECNICO.md, sección 10.
// No es un modelo organizacional (no tiene organizacionId, no vive en ORGANIZACIONAL_MODELS)
// — mismo tratamiento que Organizacion misma: aislamiento manual, nunca por la extensión de
// Prisma. Una Organizacion pertenece, como máximo, a un GrupoEconomico (relación opcional).
model GrupoEconomico {
  id        String   @id @default(uuid())
  nombre    String
  createdAt DateTime @default(now())

  organizaciones Organizacion[]
}

// Bloque 8.1.b, Etapa 1 (Schema inicial) — fundamento del modelo multiempresa.
// Ver BLOQUE8.1_DISENO_MULTIEMPRESA.md y BLOQUE8.1_PLAN_IMPLEMENTACION_MULTIEMPRESA.md.
// Campos mínimos para identificar una empresa — sin configuración comercial, moneda,
// branding, planes ni límites todavía (fuera de alcance de esta etapa).
model Organizacion {
  id               String   @id @default(uuid())
  nombre           String
  razonSocial      String?
  cuit             String?  @unique
  domicilio        String?
  telefono         String?
  email            String?
  zonaHoraria      String?
  moneda           String?
  // Bloque 10.1 — opcional y nulo por defecto: una organización sin grupo asignado sigue
  // funcionando exactamente igual que en v1.0 (GRUPO_ECONOMICO_DISENO_TECNICO.md, sección 1).
  grupoEconomicoId String?
  createdAt        DateTime @default(now())

  grupoEconomico GrupoEconomico? @relation(fields: [grupoEconomicoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  usuarios               Usuario[]
  clientes               Cliente[]
  contactos              Contacto[]
  productores            Productor[]
  transportistas         Transportista[]
  choferes               Chofer[]
  vehiculos              Vehiculo[]
  cereales               Cereal[]
  ubicaciones            Ubicacion[]
  tiposGasto             TipoGasto[]
  viajes                 Viaje[]
  historialEstadoViajes  HistorialEstadoViaje[]
  anticiposGasto         AnticipoGasto[]
  liquidaciones          Liquidacion[]
  liquidacionesViaje     LiquidacionViaje[]
  liquidacionMovimientos LiquidacionMovimiento[]
  facturas               Factura[]
  facturasViaje          FacturaViaje[]
  cobranzas              Cobranza[]
  auditLogs              AuditLog[]
  passwordResetTokens    PasswordResetToken[]
  invitacionesUsuario    InvitacionUsuario[]

  @@index([grupoEconomicoId])
}

model Usuario {
  id             String    @id @default(uuid())
  organizacionId String
  nombre         String
  email          String    @unique
  passwordHash   String
  rol            RolNombre
  activo         Boolean   @default(true)
  createdAt      DateTime  @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  viajesCreados        Viaje[]                @relation("ViajeCreadoPor")
  historialCambios     HistorialEstadoViaje[]
  anticiposRegistrados AnticipoGasto[]
  liquidacionesCreadas Liquidacion[]          @relation("LiquidacionCreadaPor")
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
  invitacionesCreadas  InvitacionUsuario[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
}

// Bloque 9.1/9.3 — token de un solo uso para activación de cuenta nueva (creada por un
// administrador) y para recuperación de contraseña olvidada. Se guarda únicamente el hash
// del token (tokenHash), nunca el valor en texto plano — mismo principio que Usuario.passwordHash.
// Se consulta con el cliente crudo de Prisma en el momento de canjearlo (BLOQUE9_DISENO_
// ADMINISTRACION.md, sección 5): todavía no existe contexto de organización autenticado en
// ese momento. Se genera, en cambio, siempre con ORGANIZACION_PRISMA (acción administrativa
// autenticada).
model PasswordResetToken {
  id             String    @id @default(uuid())
  organizacionId String
  usuarioId      String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  usuario      Usuario       @relation(fields: [usuarioId, organizacionId], references: [id, organizacionId], onDelete: Cascade, onUpdate: Cascade)

  @@index([organizacionId])
  @@index([usuarioId])
}

// Bloque 9.6 — invitación de un usuario que todavía no existe. Modelo separado de
// PasswordResetToken a propósito (BLOQUE9_DISENO_ADMINISTRACION.md, sección 4): ese modelo
// exige una FK obligatoria a un Usuario ya existente, y acá todavía no hay ninguno — el Usuario
// real se crea recién al aceptar (sección 5, "Decisión recomendada"), nunca antes, precisamente
// para no dejar bloqueado un email (único global en Usuario) por una invitación nunca aceptada.
model InvitacionUsuario {
  id             String    @id @default(uuid())
  organizacionId String
  email          String
  nombre         String
  rol            RolNombre
  tokenHash      String    @unique
  expiresAt      DateTime
  aceptadaEn     DateTime?
  creadaPorId    String
  createdAt      DateTime  @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  creadaPor    Usuario       @relation(fields: [creadaPorId, organizacionId], references: [id, organizacionId], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizacionId])
  @@index([email])
}

model Cliente {
  id                     String   @id @default(uuid())
  organizacionId         String
  razonSocial            String
  cuit                   String
  condicionesComerciales String?
  activo                 Boolean  @default(true)
  createdAt              DateTime @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  contactos Contacto[]
  viajes    Viaje[]
  facturas  Factura[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, cuit])
}

model Contacto {
  id             String  @id @default(uuid())
  organizacionId String
  clienteId      String
  nombre         String
  telefono       String?
  email          String?

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cliente      Cliente       @relation(fields: [clienteId, organizacionId], references: [id, organizacionId], onDelete: Cascade)

  @@index([organizacionId])
}

model Productor {
  id             String  @id @default(uuid())
  organizacionId String
  nombre         String
  cuit           String?
  localidad      String?

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  viajes       Viaje[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, cuit])
}

model Transportista {
  id             String   @id @default(uuid())
  organizacionId String
  razonSocial    String
  cuit           String
  domicilio      String?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  choferes      Chofer[]
  vehiculos     Vehiculo[]
  viajes        Viaje[]
  liquidaciones Liquidacion[]
  anticipos     AnticipoGasto[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, cuit])
}

model Chofer {
  id                  String    @id @default(uuid())
  organizacionId      String
  transportistaId     String
  nombre              String
  dni                 String?
  cuil                String
  comisionPct         Float     @default(0)
  licenciaNumero      String?
  licenciaVencimiento DateTime?
  telefono            String?
  activo              Boolean   @default(true)

  organizacion  Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  transportista Transportista @relation(fields: [transportistaId, organizacionId], references: [id, organizacionId])

  viajes        Viaje[]
  anticipos     AnticipoGasto[]
  liquidaciones Liquidacion[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, dni])
  @@unique([organizacionId, cuil])
}

model Vehiculo {
  id                String       @id @default(uuid())
  organizacionId    String
  transportistaId   String
  patente           String
  marca             String?
  modelo            String?
  tipo              TipoVehiculo
  capacidadKg       Float?
  vencimientoRto    DateTime?
  vencimientoSeguro DateTime?
  activo            Boolean      @default(true)

  organizacion  Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  transportista Transportista @relation(fields: [transportistaId, organizacionId], references: [id, organizacionId])

  viajesComoCamion   Viaje[] @relation("ViajeCamion")
  viajesComoAcoplado Viaje[] @relation("ViajeAcoplado")

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, patente])
}

model Cereal {
  id             String  @id @default(uuid())
  organizacionId String
  nombre         String

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  viajes       Viaje[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, nombre])
}

model Ubicacion {
  id             String        @id @default(uuid())
  organizacionId String
  nombre         String
  tipo           TipoUbicacion
  localidad      String?

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  viajesOrigen  Viaje[] @relation("ViajeOrigen")
  viajesDestino Viaje[] @relation("ViajeDestino")

  @@index([organizacionId])
  @@unique([id, organizacionId])
}

model TipoGasto {
  id                String  @id @default(uuid())
  organizacionId    String
  nombre            String
  afectaLiquidacion Boolean @default(true)

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  anticipos   AnticipoGasto[]
  movimientos LiquidacionMovimiento[]

  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, nombre])
}

model Viaje {
  id                String                    @id @default(uuid())
  organizacionId    String
  numeroViaje       Int                       @default(autoincrement())
  fecha             DateTime
  cartaPorte        String
  ctg               String
  cerealId          String
  clienteId         String
  productorId       String?
  transportistaId   String
  choferId          String
  camionId          String
  acopladoId        String?
  origenId          String
  destinoId         String
  toneladas         Float
  tarifaTonelada    Float
  importeTotal      Float
  estado            EstadoViajeEnum           @default(PENDIENTE)
  estadoFacturacion EstadoFacturacionEnum     @default(PENDIENTE_DE_FACTURAR)
  estadoLiquidacion EstadoLiquidacionItemEnum @default(PENDIENTE)
  observaciones     String?
  creadoPorId       String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  organizacion  Organizacion?  @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cereal        Cereal         @relation(fields: [cerealId, organizacionId], references: [id, organizacionId])
  cliente       Cliente        @relation(fields: [clienteId, organizacionId], references: [id, organizacionId])
  productor     Productor?     @relation(fields: [productorId, organizacionId], references: [id, organizacionId])
  transportista Transportista  @relation(fields: [transportistaId, organizacionId], references: [id, organizacionId])
  chofer        Chofer         @relation(fields: [choferId, organizacionId], references: [id, organizacionId])
  camion        Vehiculo       @relation("ViajeCamion", fields: [camionId, organizacionId], references: [id, organizacionId])
  acoplado      Vehiculo?      @relation("ViajeAcoplado", fields: [acopladoId, organizacionId], references: [id, organizacionId])
  origen        Ubicacion      @relation("ViajeOrigen", fields: [origenId, organizacionId], references: [id, organizacionId])
  destino       Ubicacion      @relation("ViajeDestino", fields: [destinoId, organizacionId], references: [id, organizacionId])
  creadoPor     Usuario?       @relation("ViajeCreadoPor", fields: [creadoPorId, organizacionId], references: [id, organizacionId])

  historial              HistorialEstadoViaje[]
  anticipos              AnticipoGasto[]
  liquidacionesViaje     LiquidacionViaje[]
  facturasViaje          FacturaViaje[]
  liquidacionMovimientos LiquidacionMovimiento[]

  @@index([fecha])
  @@index([clienteId])
  @@index([transportistaId])
  @@index([estado])
  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, ctg])
}

model HistorialEstadoViaje {
  id             String   @id @default(uuid())
  organizacionId String
  viajeId        String
  estadoAnterior String?
  estadoNuevo    String
  usuarioId      String?
  fecha          DateTime @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  viaje        Viaje         @relation(fields: [viajeId, organizacionId], references: [id, organizacionId], onDelete: Cascade)
  usuario      Usuario?      @relation(fields: [usuarioId, organizacionId], references: [id, organizacionId])

  @@index([viajeId])
  @@index([organizacionId])
}

model AnticipoGasto {
  id              String   @id @default(uuid())
  organizacionId  String
  viajeId         String?
  choferId        String
  transportistaId String
  tipoGastoId     String
  fecha           DateTime
  importe         Float
  observaciones   String?
  usuarioId       String?
  comprobanteUrl  String?
  anulado         Boolean  @default(false)
  anuladoMotivo   String?
  liquidado       Boolean  @default(false)
  createdAt       DateTime @default(now())

  organizacion  Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  viaje         Viaje?        @relation(fields: [viajeId, organizacionId], references: [id, organizacionId])
  chofer        Chofer        @relation(fields: [choferId, organizacionId], references: [id, organizacionId])
  transportista Transportista @relation(fields: [transportistaId, organizacionId], references: [id, organizacionId])
  tipoGasto     TipoGasto     @relation(fields: [tipoGastoId, organizacionId], references: [id, organizacionId])
  usuario       Usuario?      @relation(fields: [usuarioId, organizacionId], references: [id, organizacionId])

  liquidacionMovimientos LiquidacionMovimiento[]

  @@index([choferId, fecha])
  @@index([transportistaId, fecha])
  @@index([organizacionId])
  @@unique([id, organizacionId])
}

model Liquidacion {
  id              String                @id @default(uuid())
  organizacionId  String
  numero          Int                   @default(autoincrement())
  tipo            TipoLiquidacion
  transportistaId String?
  choferId        String?
  periodoDesde    DateTime
  periodoHasta    DateTime
  estado          EstadoLiquidacionEnum @default(BORRADOR)
  comisionPct     Float                 @default(0)
  totalBruto      Float                 @default(0)
  totalAnticipos  Float                 @default(0)
  totalDescuentos Float                 @default(0)
  netoPagar       Float                 @default(0)
  fechaPago       DateTime?
  creadoPorId     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organizacion  Organizacion?  @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  transportista Transportista? @relation(fields: [transportistaId, organizacionId], references: [id, organizacionId])
  chofer        Chofer?        @relation(fields: [choferId, organizacionId], references: [id, organizacionId])
  creadoPor     Usuario?       @relation("LiquidacionCreadaPor", fields: [creadoPorId, organizacionId], references: [id, organizacionId])

  viajes      LiquidacionViaje[]
  movimientos LiquidacionMovimiento[]

  @@index([transportistaId])
  @@index([choferId])
  @@index([organizacionId])
  @@unique([id, organizacionId])
}

model LiquidacionViaje {
  id             String  @id @default(uuid())
  organizacionId String
  liquidacionId  String
  viajeId        String
  subtotal       Float
  comisionPct    Float
  comisionMonto  Float
  totalViaje     Float

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  liquidacion  Liquidacion   @relation(fields: [liquidacionId, organizacionId], references: [id, organizacionId], onDelete: Cascade)
  viaje        Viaje         @relation(fields: [viajeId, organizacionId], references: [id, organizacionId])

  @@index([liquidacionId])
  @@index([viajeId])
  @@index([organizacionId])
}

model LiquidacionMovimiento {
  id              String   @id @default(uuid())
  organizacionId  String
  liquidacionId   String
  viajeId         String?
  tipoGastoId     String
  anticipoGastoId String?
  importe         Float
  fecha           DateTime
  observacion     String?
  comprobanteUrl  String?

  organizacion  Organizacion?  @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  liquidacion   Liquidacion    @relation(fields: [liquidacionId, organizacionId], references: [id, organizacionId], onDelete: Cascade)
  viaje         Viaje?         @relation(fields: [viajeId, organizacionId], references: [id, organizacionId])
  tipoGasto     TipoGasto      @relation(fields: [tipoGastoId, organizacionId], references: [id, organizacionId])
  anticipoGasto AnticipoGasto? @relation(fields: [anticipoGastoId, organizacionId], references: [id, organizacionId])

  @@index([liquidacionId])
  @@index([anticipoGastoId])
  @@index([organizacionId])
}

model Factura {
  id             String            @id @default(uuid())
  organizacionId String
  clienteId      String
  numero         String
  fecha          DateTime
  vencimiento    DateTime
  importe        Float
  estado         EstadoFacturaEnum @default(FACTURADO)
  createdAt      DateTime          @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cliente      Cliente       @relation(fields: [clienteId, organizacionId], references: [id, organizacionId])

  viajes    FacturaViaje[]
  cobranzas Cobranza[]

  @@index([clienteId])
  @@index([vencimiento])
  @@index([organizacionId])
  @@unique([id, organizacionId])
  @@unique([organizacionId, numero])
}

model FacturaViaje {
  id             String  @id @default(uuid())
  organizacionId String
  facturaId      String
  viajeId        String
  importeViaje   Float

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  factura      Factura       @relation(fields: [facturaId, organizacionId], references: [id, organizacionId], onDelete: Cascade)
  viaje        Viaje         @relation(fields: [viajeId, organizacionId], references: [id, organizacionId])

  @@index([facturaId])
  @@index([viajeId])
  @@index([organizacionId])
}

model Cobranza {
  id             String    @id @default(uuid())
  organizacionId String
  facturaId      String
  fecha          DateTime
  importe        Float
  medioPago      String?
  observacion    String?
  anulada        Boolean   @default(false)
  anuladaMotivo  String?
  anuladaFecha   DateTime?

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  factura      Factura       @relation(fields: [facturaId, organizacionId], references: [id, organizacionId], onDelete: Cascade)

  @@index([facturaId])
  @@index([organizacionId])
}

model AuditLog {
  id              String   @id @default(uuid())
  organizacionId  String
  usuarioId       String?
  entidad         String
  entidadId       String
  accion          String
  datosAnteriores Json?
  datosNuevos     Json?
  fecha           DateTime @default(now())

  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  usuario      Usuario?      @relation(fields: [usuarioId, organizacionId], references: [id, organizacionId])

  @@index([entidad, entidadId])
  @@index([organizacionId])
}
