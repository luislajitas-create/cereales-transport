generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolNombre {
  ADMINISTRADOR
  GERENCIA
  OPERACIONES
  LIQUIDACIONES
  FACTURACION
  LECTURA
}

enum EstadoViajeEnum {
  PENDIENTE
  ASIGNADO
  EN_CARGA
  CARGADO
  EN_TRANSITO
  DESCARGADO
  CANCELADO
}

enum EstadoFacturacionEnum {
  PENDIENTE_DE_FACTURAR
  FACTURADO
  COBRADO_PARCIAL
  COBRADO_TOTAL
  ANULADO
}

enum EstadoLiquidacionItemEnum {
  PENDIENTE
  LIQUIDADO
  PAGADO
}

enum TipoVehiculo {
  CAMION
  ACOPLADO
}

enum TipoUbicacion {
  ACOPIO
  PLANTA
  PUERTO
  CAMPO
  OTRO
}

enum TipoLiquidacion {
  TRANSPORTISTA
  CHOFER
}

enum EstadoLiquidacionEnum {
  BORRADOR
  CONFIRMADA
  PAGADA
  ANULADA
}

enum EstadoFacturaEnum {
  FACTURADO
  COBRADO_PARCIAL
  COBRADO_TOTAL
  ANULADO
}

enum EstadoSolicitudCombustible {
  BORRADOR
  SOLICITADO
  AUTORIZADO
  RECHAZADO
  MODIFICADO
  ENVIADO
  RECIBIDO
  LIQUIDADO
  CANCELADO
}

enum EstadoCuentaCorriente {
  ACTIVA
  SALDADA
  SUSPENDIDA
}

enum TipoMetodoPago {
  TRANSFERENCIA
  CHEQUE
  EFECTIVO
  TARJETA_CREDITO
  OTRO
}

enum TipoMovimientoCuenta {
  COMPRA
  PAGO
  AJUSTE
  DEVOLUCION
}

model Usuario {
  id           String    @id @default(uuid())
  nombre       String
  email        String    @unique
  passwordHash String
  rol          RolNombre
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  viajesCreados           Viaje[]                          @relation("ViajeCreadoPor")
  historialCambios        HistorialEstadoViaje[]
  anticiposRegistrados    AnticipoGasto[]
  liquidacionesCreadas    Liquidacion[]                    @relation("LiquidacionCreadaPor")
  auditLogs               AuditLog[]
  solicitudesAutorizadas  SolicitudCombustible[]           @relation("SolicitudAutorizada")
}

model Cliente {
  id                     String   @id @default(uuid())
  razonSocial            String
  cuit                   String   @unique
  condicionesComerciales String?
  activo                 Boolean  @default(true)
  createdAt              DateTime @default(now())

  contactos Contacto[]
  viajes    Viaje[]
  facturas  Factura[]
}

model Contacto {
  id        String  @id @default(uuid())
  clienteId String
  nombre    String
  telefono  String?
  email     String?
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Productor {
  id        String  @id @default(uuid())
  nombre    String
  cuit      String?
  localidad String?
  viajes    Viaje[]
}

model Transportista {
  id          String   @id @default(uuid())
  razonSocial String
  cuit        String   @unique
  domicilio   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  choferes                 Chofer[]
  vehiculos                Vehiculo[]
  viajes                   Viaje[]
  liquidaciones            Liquidacion[]
  anticipos                AnticipoGasto[]
  solicitudesCombustible   SolicitudCombustible[]
  liquidacionesCombustible LiquidacionCombustible[]
}

model Chofer {
  id                  String   @id @default(uuid())
  transportistaId     String
  nombre              String
  dni                 String?
  cuil                String   @unique
  comisionPct         Float    @default(0)
  licenciaNumero      String?
  licenciaVencimiento DateTime?
  telefono            String?

  transportista            Transportista                   @relation(fields: [transportistaId], references: [id])
  viajes                   Viaje[]
  anticipos                AnticipoGasto[]
  liquidaciones            Liquidacion[]
  solicitudesCombustible   SolicitudCombustible[]
  liquidacionesCombustible LiquidacionCombustible[]
}

model Vehiculo {
  id                 String       @id @default(uuid())
  transportistaId    String
  patente            String       @unique
  marca              String?
  modelo             String?
  tipo               TipoVehiculo
  capacidadKg        Float?
  vencimientoRto     DateTime?
  vencimientoSeguro  DateTime?

  transportista     Transportista @relation(fields: [transportistaId], references: [id])
  viajesComoCamion  Viaje[]       @relation("ViajeCamion")
  viajesComoAcoplado Viaje[]      @relation("ViajeAcoplado")
}

model Cereal {
  id     String  @id @default(uuid())
  nombre String  @unique
  viajes Viaje[]
}

model Ubicacion {
  id        String        @id @default(uuid())
  nombre    String
  tipo      TipoUbicacion
  localidad String?

  viajesOrigen  Viaje[] @relation("ViajeOrigen")
  viajesDestino Viaje[] @relation("ViajeDestino")
}

model TipoGasto {
  id                String  @id @default(uuid())
  nombre            String  @unique
  afectaLiquidacion Boolean @default(true)

  anticipos  AnticipoGasto[]
  movimientos LiquidacionMovimiento[]
}

model Viaje {
  id                 String                 @id @default(uuid())
  numeroViaje        Int                    @default(autoincrement())
  fecha              DateTime
  cartaPorte         String
  ctg                String                 @unique
  cerealId           String
  clienteId          String
  productorId        String?
  transportistaId    String
  choferId           String
  camionId           String
  acopladoId         String?
  origenId           String
  destinoId          String
  toneladas          Float
  tarifaTonelada     Float
  importeTotal       Float
  estado             EstadoViajeEnum        @default(PENDIENTE)
  estadoFacturacion  EstadoFacturacionEnum  @default(PENDIENTE_DE_FACTURAR)
  estadoLiquidacion  EstadoLiquidacionItemEnum @default(PENDIENTE)
  observaciones      String?
  creadoPorId        String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  cereal         Cereal         @relation(fields: [cerealId], references: [id])
  cliente        Cliente        @relation(fields: [clienteId], references: [id])
  productor      Productor?     @relation(fields: [productorId], references: [id])
  transportista  Transportista  @relation(fields: [transportistaId], references: [id])
  chofer         Chofer         @relation(fields: [choferId], references: [id])
  camion         Vehiculo       @relation("ViajeCamion", fields: [camionId], references: [id])
  acoplado       Vehiculo?      @relation("ViajeAcoplado", fields: [acopladoId], references: [id])
  origen         Ubicacion      @relation("ViajeOrigen", fields: [origenId], references: [id])
  destino        Ubicacion      @relation("ViajeDestino", fields: [destinoId], references: [id])
  creadoPor      Usuario?       @relation("ViajeCreadoPor", fields: [creadoPorId], references: [id])

  historial          HistorialEstadoViaje[]
  anticipos           AnticipoGasto[]
  liquidacionViaje     LiquidacionViaje?
  facturaViaje         FacturaViaje?
  liquidacionMovimientos LiquidacionMovimiento[]

  @@index([fecha])
  @@index([clienteId])
  @@index([transportistaId])
  @@index([estado])
}

model HistorialEstadoViaje {
  id             String   @id @default(uuid())
  viajeId        String
  estadoAnterior String?
  estadoNuevo    String
  usuarioId      String?
  fecha          DateTime @default(now())

  viaje   Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([viajeId])
}

model AnticipoGasto {
  id              String    @id @default(uuid())
  viajeId         String?
  choferId        String
  transportistaId String
  tipoGastoId     String
  fecha           DateTime
  importe         Float
  observaciones   String?
  usuarioId       String?
  comprobanteUrl  String?
  anulado         Boolean   @default(false)
  anuladoMotivo   String?
  liquidado       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  viaje         Viaje?        @relation(fields: [viajeId], references: [id])
  chofer        Chofer        @relation(fields: [choferId], references: [id])
  transportista Transportista @relation(fields: [transportistaId], references: [id])
  tipoGasto     TipoGasto     @relation(fields: [tipoGastoId], references: [id])
  usuario       Usuario?      @relation(fields: [usuarioId], references: [id])

  @@index([choferId, fecha])
  @@index([transportistaId, fecha])
}

model Liquidacion {
  id              String                @id @default(uuid())
  numero          Int                   @default(autoincrement())
  tipo            TipoLiquidacion
  transportistaId String?
  choferId        String?
  periodoDesde    DateTime
  periodoHasta    DateTime
  estado          EstadoLiquidacionEnum @default(BORRADOR)
  comisionPct     Float                 @default(0)
  totalBruto      Float                 @default(0)
  totalAnticipos  Float                 @default(0)
  totalDescuentos Float                 @default(0)
  netoPagar       Float                 @default(0)
  fechaPago       DateTime?
  creadoPorId     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  transportista Transportista? @relation(fields: [transportistaId], references: [id])
  chofer        Chofer?        @relation(fields: [choferId], references: [id])
  creadoPor     Usuario?       @relation("LiquidacionCreadaPor", fields: [creadoPorId], references: [id])

  viajes      LiquidacionViaje[]
  movimientos LiquidacionMovimiento[]

  @@index([transportistaId])
  @@index([choferId])
}

model LiquidacionViaje {
  id            String  @id @default(uuid())
  liquidacionId String
  viajeId       String  @unique
  subtotal      Float
  comisionPct   Float
  comisionMonto Float
  totalViaje    Float

  liquidacion Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  viaje       Viaje       @relation(fields: [viajeId], references: [id])

  @@index([liquidacionId])
}

model LiquidacionMovimiento {
  id            String   @id @default(uuid())
  liquidacionId String
  viajeId       String?
  tipoGastoId   String
  importe       Float
  fecha         DateTime
  observacion   String?
  comprobanteUrl String?

  liquidacion Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  viaje       Viaje?      @relation(fields: [viajeId], references: [id])
  tipoGasto   TipoGasto   @relation(fields: [tipoGastoId], references: [id])

  @@index([liquidacionId])
}

model Factura {
  id          String            @id @default(uuid())
  clienteId   String
  numero      String            @unique
  fecha       DateTime
  vencimiento DateTime
  importe     Float
  estado      EstadoFacturaEnum @default(FACTURADO)
  createdAt   DateTime          @default(now())

  cliente   Cliente         @relation(fields: [clienteId], references: [id])
  viajes    FacturaViaje[]
  cobranzas Cobranza[]

  @@index([clienteId])
  @@index([vencimiento])
}

model FacturaViaje {
  id            String  @id @default(uuid())
  facturaId     String
  viajeId       String  @unique
  importeViaje  Float

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  viaje   Viaje   @relation(fields: [viajeId], references: [id])

  @@index([facturaId])
}

model Cobranza {
  id          String   @id @default(uuid())
  facturaId   String
  fecha       DateTime
  importe     Float
  medioPago   String?
  observacion String?

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([facturaId])
}

model AuditLog {
  id              String   @id @default(uuid())
  usuarioId       String?
  entidad         String
  entidadId       String
  accion          String
  datosAnteriores Json?
  datosNuevos     Json?
  fecha           DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidad, entidadId])
}

# ============================================================
# FUEL MANAGEMENT MODULE (GESTIÓN DE COMBUSTIBLES)
# ============================================================

model EstacionServicio {
  id                String   @id @default(uuid())
  nombre            String
  localidad         String
  direccion         String?
  telefono          String?
  contacto          String?
  email             String?
  coordenadas       String?  # JSON: {"lat": -32.94, "lng": -60.74}
  activa            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  solicitudes           SolicitudCombustible[]
  cuentaCorriente       CuentaCorrienteEstacion?
  pagos                 PagoEstacion[]
  reconciliaciones      ReconciliacionCombustible[]

  @@index([localidad])
  @@index([activa])
}

model SolicitudCombustible {
  id                    String                       @id @default(uuid())
  numero                Int                          @default(autoincrement())
  choferId              String
  transportistaId       String
  estacionId            String
  fecha                 DateTime
  cantidadSolicitada    Float                        # litros
  cantidadRecibida      Float?                       # litros (populated after reception)
  precioEstimado        Float                        # ARS
  precioFinal           Float?                       # ARS (actual price)
  estado                EstadoSolicitudCombustible  @default(BORRADOR)
  observaciones         String?

  # Authorization fields
  autorizadoPorId       String?
  fechaAutorizacion     DateTime?

  # Dispatch fields
  enviadoEl             DateTime?
  numeroDespacho        String?

  # Reception fields
  recibidoEl            DateTime?
  comprobante           String?  # URL to gas station receipt
  discrepancia          Boolean  @default(false)
  motivoDiscrepancia    String?

  # Reconciliation
  reconciliadoEl        DateTime?
  liquidacionId         String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  chofer                Chofer                      @relation(fields: [choferId], references: [id])
  transportista         Transportista              @relation(fields: [transportistaId], references: [id])
  estacion              EstacionServicio           @relation(fields: [estacionId], references: [id])
  autorizadoPor         Usuario?                   @relation("SolicitudAutorizada", fields: [autorizadoPorId], references: [id])
  liquidacion           LiquidacionCombustible?    @relation(fields: [liquidacionId], references: [id])

  @@unique([numero])
  @@index([choferId, fecha])
  @@index([estacionId])
  @@index([estado])
  @@index([transportistaId])
}

model LiquidacionCombustible {
  id                    String                    @id @default(uuid())
  numero                Int                       @default(autoincrement())
  choferId              String
  transportistaId       String
  liquidacionId         String?                   # Reference to Liquidacion model
  fecha                 DateTime
  cantidadLitros        Float
  costoPorLitro         Float
  costoTotal            Float
  observaciones         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  chofer                Chofer                    @relation(fields: [choferId], references: [id])
  transportista         Transportista             @relation(fields: [transportistaId], references: [id])

  solicitudes           SolicitudCombustible[]

  @@unique([numero])
  @@index([choferId, fecha])
  @@index([liquidacionId])
}

model CuentaCorrienteEstacion {
  id                    String                   @id @default(uuid())
  estacionId            String                   @unique
  saldo                 Float                    @default(0)  # Positive = we owe, negative = credit
  estado                EstadoCuentaCorriente    @default(ACTIVA)
  ultimaActualizacion   DateTime                 @updatedAt
  observaciones         String?

  estacion              EstacionServicio        @relation(fields: [estacionId], references: [id], onDelete: Cascade)
  movimientos           MovimientoCuentaCorriente[]
  pagos                 PagoEstacion[]

  @@index([estacionId])
}

model MovimientoCuentaCorriente {
  id                    String                    @id @default(uuid())
  cuentaCorrienteId     String
  tipoMovimiento        TipoMovimientoCuenta
  fecha                 DateTime
  monto                 Float
  referencia            String?                   # solicitudId, pagoId, etc
  observacion           String?

  cuentaCorriente       CuentaCorrienteEstacion  @relation(fields: [cuentaCorrienteId], references: [id], onDelete: Cascade)

  @@index([cuentaCorrienteId])
  @@index([fecha])
}

model PagoEstacion {
  id                    String             @id @default(uuid())
  numero                Int                @default(autoincrement())
  estacionId            String
  cuentaCorrienteId     String
  fecha                 DateTime
  importePago           Float
  metodoPago            TipoMetodoPago
  numeroComprobante     String?
  descripcion           String?
  conciliado            Boolean            @default(false)
  createdAt             DateTime           @default(now())

  estacion              EstacionServicio   @relation(fields: [estacionId], references: [id])
  cuentaCorriente       CuentaCorrienteEstacion @relation(fields: [cuentaCorrienteId], references: [id], onDelete: Cascade)

  @@unique([numero])
  @@index([estacionId])
  @@index([fecha])
}

model ReconciliacionCombustible {
  id                        String             @id @default(uuid())
  estacionId                String
  fecha                     DateTime
  fuente                    String             # MANUAL, AUTO_IMPORT, RECONCILIACION
  solicitudesMatches        Int                @default(0)
  solicitudesDiscrepancias  Int                @default(0)
  montoTotalSolicitado      Float              @default(0)
  montoTotalRecibido        Float              @default(0)
  diferencia                Float              @default(0)
  observaciones             String?
  createdAt                 DateTime           @default(now())

  estacion              EstacionServicio   @relation(fields: [estacionId], references: [id])
  importFiles           ImportacionCombustible[]

  @@index([estacionId])
  @@index([fecha])
}

model ImportacionCombustible {
  id                    String             @id @default(uuid())
  reconciliacionId      String
  archivo               String             # URL to uploaded file
  archivoNombre         String
  tipoArchivo           String             # EXCEL, PDF
  fechaImportacion      DateTime           @default(now())
  lineasProcesadas      Int                @default(0)
  lineasConError        Int                @default(0)
  detallesError         String?            # JSON array of errors
  estado                String             # PENDIENTE, PROCESADO, CON_ERRORES
  procesadoEl           DateTime?
  createdAt             DateTime           @default(now())

  reconciliacion        ReconciliacionCombustible @relation(fields: [reconciliacionId], references: [id], onDelete: Cascade)

  @@index([reconciliacionId])
}

model ConsumoCombustibleEstadistica {
  id                    String             @id @default(uuid())
  choferId              String?
  transportistaId       String?
  periodo               String             # YYYYMM
  cantidadLitros        Float
  costoTotal            Float              # ARS
  costoPorLitro         Float?
  createdAt             DateTime           @default(now())

  @@unique([choferId, periodo])
  @@unique([transportistaId, periodo])
  @@index([periodo])
}
