generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolNombre {
  ADMINISTRADOR
  GERENCIA
  OPERACIONES
  LIQUIDACIONES
  FACTURACION
  LECTURA
}

enum EstadoViajeEnum {
  PENDIENTE
  ASIGNADO
  EN_CARGA
  CARGADO
  EN_TRANSITO
  DESCARGADO
  CANCELADO
}

enum EstadoFacturacionEnum {
  PENDIENTE_DE_FACTURAR
  FACTURADO
  COBRADO_PARCIAL
  COBRADO_TOTAL
  ANULADO
}

enum EstadoLiquidacionItemEnum {
  PENDIENTE
  LIQUIDADO
  PAGADO
}

enum TipoVehiculo {
  CAMION
  ACOPLADO
}

enum TipoUbicacion {
  ACOPIO
  PLANTA
  PUERTO
  CAMPO
  OTRO
}

enum TipoLiquidacion {
  TRANSPORTISTA
  CHOFER
}

enum EstadoLiquidacionEnum {
  BORRADOR
  CONFIRMADA
  PAGADA
  ANULADA
}

enum EstadoFacturaEnum {
  FACTURADO
  COBRADO_PARCIAL
  COBRADO_TOTAL
  ANULADO
}

enum EstadoSolicitudCombustible {
  BORRADOR
  SOLICITADO
  AUTORIZADO
  RECHAZADO
  MODIFICADO
  ENVIADO
  RECIBIDO
  LIQUIDADO
  CANCELADO
}

enum EstadoCuentaCorriente {
  ACTIVA
  SALDADA
  SUSPENDIDA
}

enum TipoMetodoPago {
  TRANSFERENCIA
  CHEQUE
  EFECTIVO
  TARJETA_CREDITO
  OTRO
}

enum TipoMovimientoCuenta {
  COMPRA
  PAGO
  AJUSTE
  DEVOLUCION
}

model Usuario {
  id           String    @id @default(uuid())
  nombre       String
  email        String    @unique
  passwordHash String
  rol          RolNombre
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  viajesCreados           Viaje[]                          @relation("ViajeCreadoPor")
  historialCambios        HistorialEstadoViaje[]
  anticiposRegistrados    AnticipoGasto[]
  liquidacionesCreadas    Liquidacion[]                    @relation("LiquidacionCreadaPor")
  auditLogs               AuditLog[]
  solicitudesAutorizadas  SolicitudCombustible[]           @relation("SolicitudAutorizada")
}

model Cliente {
  id                     String   @id @default(uuid())
  razonSocial            String
  cuit                   String   @unique
  condicionesComerciales String?
  activo                 Boolean  @default(true)
  createdAt              DateTime @default(now())

  contactos Contacto[]
  viajes    Viaje[]
  facturas  Factura[]
}

model Contacto {
  id        String  @id @default(uuid())
  clienteId String
  nombre    String
  telefono  String?
  email     String?
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Productor {
  id        String  @id @default(uuid())
  nombre    String
  cuit      String?
  domicilio String?
  activo    Boolean @default(true)

  viajes Viaje[]
}

model Ubicacion {
  id        String       @id @default(uuid())
  nombre    String
  tipo      TipoUbicacion
  domicilio String?
  localidad String?

  viajes Viaje[]
}

model Transportista {
  id          String   @id @default(uuid())
  razonSocial String
  cuit        String   @unique
  domicilio   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  choferes      Chofer[]
  vehiculos     Vehiculo[]
  viajes        Viaje[]
  liquidaciones Liquidacion[]
  anticipos     AnticipoGasto[]
}

model Chofer {
  id                  String   @id @default(uuid())
  transportistaId     String
  nombre              String
  dni                 String?
  cuil                String   @unique
  comisionPct         Float    @default(0)
  licenciaNumero      String?
  licenciaVencimiento DateTime?
  telefono            String?

  transportista            Transportista                   @relation(fields: [transportistaId], references: [id])
  viajes                   Viaje[]
  anticipos                AnticipoGasto[]
  liquidaciones            Liquidacion[]
  solicitudesCombustible   SolicitudCombustible[]
  estadisticasCombustible  ConsumoCombustibleEstadistica[]
}

model Vehiculo {
  id                 String       @id @default(uuid())
  transportistaId    String
  patente            String       @unique
  marca              String?
  modelo             String?
  tipo               TipoVehiculo
  capacidadKg        Float?
  vencimientoRto     DateTime?
  vencimientoSeguro  DateTime?

  transportista Transportista @relation(fields: [transportistaId], references: [id])
  viajes        Viaje[]
}

model Cereal {
  id        String  @id @default(uuid())
  nombre    String  @unique
  activo    Boolean @default(true)

  viajes Viaje[]
}

model Viaje {
  id                    String            @id @default(uuid())
  numero                Int               @unique @default(autoincrement())
  clienteId             String
  transportistaId       String
  choferId              String
  productorId           String
  cerealId              String
  origenId              String
  destinoId             String
  estado                EstadoViajeEnum
  fechaCreacion         DateTime          @default(now())
  pesoBruto             Float?
  pesoNeto              Float?
  numeroCartaPorte      String?           @unique
  numeroCTG             String?
  observaciones         String?

  cliente         Cliente              @relation(fields: [clienteId], references: [id])
  transportista   Transportista        @relation(fields: [transportistaId], references: [id])
  chofer          Chofer               @relation(fields: [choferId], references: [id])
  productor       Productor            @relation(fields: [productorId], references: [id])
  cereal          Cereal               @relation(fields: [cerealId], references: [id])
  origen          Ubicacion            @relation(name: "ViajeOrigen", fields: [origenId], references: [id])
  destino         Ubicacion            @relation(name: "ViajeDestino", fields: [destinoId], references: [id])
  creadoPor       Usuario              @relation(name: "ViajeCreadoPor", fields: [id], references: [id])
  historial       HistorialEstadoViaje[]
  facturas        Factura[]
  solicitudesCombustible SolicitudCombustible[]
}

model HistorialEstadoViaje {
  id        String   @id @default(uuid())
  viajeId   String
  estado    EstadoViajeEnum
  fecha     DateTime @default(now())
  usuario   String
  viaje     Viaje    @relation(fields: [viajeId], references: [id])
}

model AnticipoGasto {
  id                String   @id @default(uuid())
  numero            Int      @unique @default(autoincrement())
  choferId          String
  transportistaId   String
  clienteId         String
  tipo              String
  monto             Float
  fecha             DateTime @default(now())
  observaciones     String?

  chofer        Chofer        @relation(fields: [choferId], references: [id])
  transportista Transportista @relation(fields: [transportistaId], references: [id])
  cliente       Cliente       @relation(fields: [clienteId], references: [id])
}

model Liquidacion {
  id                  String             @id @default(uuid())
  numero              Int                @unique @default(autoincrement())
  tipo                TipoLiquidacion
  referenceId         String
  estado              EstadoLiquidacionEnum
  fechaCreacion       DateTime           @default(now())
  descripcion         String?
  items               LiquidacionItem[]
  creadoPor           Usuario?           @relation(name: "LiquidacionCreadaPor", fields: [createdByUserId], references: [id])
  createdByUserId     String?
}

model LiquidacionItem {
  id            String                    @id @default(uuid())
  liquidacionId String
  viajeId       String?
  concepto      String
  monto         Float
  estado        EstadoLiquidacionItemEnum
  liquidacion   Liquidacion               @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
}

model Factura {
  id                      String                @id @default(uuid())
  numero                  Int                   @unique @default(autoincrement())
  clienteId               String
  viajeId                 String?
  estado                  EstadoFacturaEnum
  monto                   Float
  montoIVA                Float                 @default(0)
  montoTotal              Float
  fechaEmision            DateTime              @default(now())
  fechaVencimiento        DateTime?
  numeroComprobante       String?
  observaciones           String?
  tieneIVA                Boolean               @default(false)

  cliente Cliente @relation(fields: [clienteId], references: [id])
  viaje   Viaje?  @relation(fields: [viajeId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  usuarioId String
  accion    String
  tabla     String
  fecha     DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

// ===== COMBUSTIBLES MODULE =====

model EstacionServicio {
  id                    String   @id @default(uuid())
  nombre                String
  domicilio             String?
  telefonoContacto      String?
  contactoNombre        String?
  numeroClientePYME     String?
  activo                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  solicitudes           SolicitudCombustible[]
  cuentaCorriente       CuentaCorrienteEstacion?
  pagos                 PagoEstacion[]
  reconciliaciones      ReconciliacionCombustible[]
  importaciones         ImportacionCombustible[]
  estadisticas          ConsumoCombustibleEstadistica[]

  @@index([activo])
}

model SolicitudCombustible {
  id                    String                       @id @default(uuid())
  numero                Int                          @unique @default(autoincrement())
  choferId              String
  viajeId               String?
  estacionId            String?
  cantidadSolicitada    Float
  cantidadRecibida      Float?
  estado                EstadoSolicitudCombustible   @default(BORRADOR)
  fechaCreacion         DateTime                     @default(now())
  fechaSolicitud        DateTime?
  fechaAutorizacion     DateTime?
  fechaEnvio            DateTime?
  fechaRecepcion        DateTime?
  fechaLiquidacion      DateTime?
  observaciones         String?
  motivoRechazo         String?
  autorizadoPor         String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  chofer                Chofer                       @relation(fields: [choferId], references: [id], onDelete: Restrict)
  viaje                 Viaje?                       @relation(fields: [viajeId], references: [id], onDelete: SetNull)
  estacion              EstacionServicio?            @relation(fields: [estacionId], references: [id], onDelete: SetNull)

  @@index([choferId])
  @@index([viajeId])
  @@index([estacionId])
  @@index([estado])
  @@index([fechaSolicitud])
}

model LiquidacionCombustible {
  id                    String                    @id @default(uuid())
  solicitudId           String                    @unique
  liquidacionId         String?
  importeLiquidado      Float
  fechaLiquidacion      DateTime                  @default(now())
  observaciones         String?
  createdAt             DateTime                  @default(now())

  solicitud             SolicitudCombustible      @relation(fields: [solicitudId], references: [id], onDelete: Restrict)
  liquidacion           Liquidacion?              @relation(fields: [liquidacionId], references: [id], onDelete: SetNull)

  @@index([liquidacionId])
}

model CuentaCorrienteEstacion {
  id                    String                   @id @default(uuid())
  estacionId            String                   @unique
  saldoActual           Float                    @default(0)
  saldoPendiente        Float                    @default(0)
  estado                EstadoCuentaCorriente    @default(ACTIVA)
  ultimaActualizacion   DateTime                 @default(now()) @updatedAt
  observaciones         String?

  estacion              EstacionServicio        @relation(fields: [estacionId], references: [id], onDelete: Cascade)
  movimientos           MovimientoCuentaCorriente[]
  pagos                 PagoEstacion[]

  @@index([estacionId])
}

model MovimientoCuentaCorriente {
  id                    String                    @id @default(uuid())
  cuentaCorrienteId     String
  tipoMovimiento        TipoMovimientoCuenta
  fecha                 DateTime
  monto                 Float
  referencia            String?
  observacion           String?

  cuentaCorriente       CuentaCorrienteEstacion  @relation(fields: [cuentaCorrienteId], references: [id], onDelete: Cascade)

  @@index([cuentaCorrienteId])
  @@index([fecha])
}

model PagoEstacion {
  id                    String             @id @default(uuid())
  numero                Int                @unique @default(autoincrement())
  estacionId            String
  cuentaCorrienteId     String
  fecha                 DateTime
  importePago           Float
  metodoPago            TipoMetodoPago
  numeroComprobante     String?
  descripcion           String?
  conciliado            Boolean            @default(false)
  createdAt             DateTime           @default(now())

  estacion              EstacionServicio   @relation(fields: [estacionId], references: [id], onDelete: Restrict)
  cuentaCorriente       CuentaCorrienteEstacion @relation(fields: [cuentaCorrienteId], references: [id], onDelete: Cascade)

  @@index([estacionId])
  @@index([fecha])
}

model ReconciliacionCombustible {
  id                          String   @id @default(uuid())
  estacionId                  String
  numeroArchivoImportacion    String?
  fechaImportacion            DateTime @default(now())
  solicitudesEncontradas      Int      @default(0)
  solicitudesReconciliadas    Int      @default(0)
  solicitudesConDiscrepancia  Int      @default(0)
  archivoOriginal             String?
  observaciones               String?
  createdAt                   DateTime @default(now())

  estacion                    EstacionServicio @relation(fields: [estacionId], references: [id], onDelete: Restrict)

  @@index([estacionId])
  @@index([fechaImportacion])
}

model ImportacionCombustible {
  id                  String    @id @default(uuid())
  estacionId          String
  nombreArchivo       String
  tipoArchivo         String
  contenidoBase64     String?
  datosExtraidos      String?
  procesada           Boolean   @default(false)
  fechaProcesamiento  DateTime?
  errorProcesamiento  String?
  createdAt           DateTime  @default(now())

  estacion            EstacionServicio @relation(fields: [estacionId], references: [id], onDelete: Restrict)

  @@index([estacionId])
  @@index([procesada])
}

model ConsumoCombustibleEstadistica {
  id                       String             @id @default(uuid())
  choferId                 String?
  estacionId               String?
  mes                      Int
  ano                      Int
  cantidadTotal            Float              @default(0)
  importeTotal             Float              @default(0)
  numeroTransacciones      Int                @default(0)
  promedioPorTransaccion   Float?
  createdAt                DateTime           @default(now())
  updatedAt               DateTime            @updatedAt

  chofer                   Chofer?            @relation(fields: [choferId], references: [id], onDelete: SetNull)
  estacion                 EstacionServicio?  @relation(fields: [estacionId], references: [id], onDelete: SetNull)

  @@index([choferId])
  @@index([estacionId])
  @@index([mes, ano])
}
