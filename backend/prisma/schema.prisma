generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolNombre {
  ADMINISTRADOR
  GERENCIA
  OPERACIONES
  LIQUIDACIONES
  FACTURACION
  LECTURA
}

enum EstadoViajeEnum {
  PENDIENTE
  ASIGNADO
  EN_CARGA
  CARGADO
  EN_TRANSITO
  DESCARGADO
  CANCELADO
}

model Usuario {
  id           String    @id @default(uuid())
  nombre       String
  email        String    @unique
  passwordHash String
  rol          RolNombre
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  viajesCreados Viaje[] @relation("ViajeCreadoPor")
}

model Cliente {
  id                     String   @id @default(uuid())
  razonSocial            String
  cuit                   String   @unique
  condicionesComerciales String?
  activo                 Boolean  @default(true)
  createdAt              DateTime @default(now())

  viajes Viaje[] @relation("ClienteViajes")
}

model Viaje {
  id           String   @id @default(uuid())
  numero       String   @unique
  estado       EstadoViajeEnum @default(PENDIENTE)

  creadoPorId  String
  creadoPor    Usuario  @relation("ViajeCreadoPor", fields: [creadoPorId], references: [id])

  clienteId    String
  cliente      Cliente  @relation("ClienteViajes", fields: [clienteId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}